// This is your Prisma schema file for the Amazon Returns & Grading Platform
// Learn more at: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// User Profiles
// ─────────────────────────────────────────────
model Profile {
  id              String            @id @default(uuid())
  email           String            @unique
  fullName        String?           @map("full_name")
  greenCredits    Int               @default(320) @map("green_credits")
  treesPlanted    Int               @default(14) @map("trees_planted")
  causesHelped    Int               @default(8) @map("causes_helped")
  totalOrdersPlaced Int             @default(0) @map("total_orders_placed")
  isBanned        Boolean           @default(false) @map("is_banned")
  createdAt       DateTime          @default(now()) @map("created_at")

  returns         Return[]
  p2pProducts     P2pProduct[]
  donationHistory DonationHistory[]
  purchaseHistory PurchaseHistory[]

  @@map("profiles")
}

// ─────────────────────────────────────────────
// Purchase History (sizes bought in past orders — powers "Use my
// previous size" in the Shoe Size Finder / fit-prevention tools)
// ─────────────────────────────────────────────
model PurchaseHistory {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  itemName    String   @map("item_name")
  category    String   // e.g. "SHOES", "APPAREL"
  sizeSystem  String   @default("IND") @map("size_system")
  size        String   // e.g. "IND 9"
  width       String?  // e.g. "Medium (Standard)"
  purchasedAt DateTime @default(now()) @map("purchased_at")

  user        Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchase_history")
}

// ─────────────────────────────────────────────
// Returns
// ─────────────────────────────────────────────
model Return {
  id                String    @id
  customerId        String?   @map("customer_id")
  customerName      String?   @map("customer_name")
  timeWindow        String?   @map("time_window")
  address           String?
  district          String?
  itemName          String    @map("item_name")
  category          String
  price             Decimal   @db.Decimal(10, 2)
  sku               String?
  imgUrl            String?   @map("img_url")
  reason            String?
  comments          String?
  status            String    @default("Pending")
  userGrade         String?   @map("user_grade")
  userConfidence    String?   @map("user_confidence")
  defects           Json      @default("[]")
  agentGrade        String    @default("") @map("agent_grade")
  agentDefects      String    @default("") @map("agent_defects")
  disagreementCount Int       @default(0) @map("disagreement_count")
  downgradeRate     String?   @map("downgrade_rate")
  routing           String?
  riskTier          String?   @map("risk_tier")
  trend30d          String?   @map("trend_30d")
  flagReason        String?   @map("flag_reason")
  aiRequestId       String?   @map("ai_request_id")
  aiStatus          String?   @map("ai_status")
  subcategory       String?
  conditionAnswers  Json      @default("{}") @map("condition_answers")
  aiNotesContradict Boolean   @default(false) @map("ai_notes_contradict")
  aiRequiresHumanReview Boolean @default(false) @map("ai_requires_human_review")
  refundStatus      String    @default("PENDING") @map("refund_status")
  fraudFlagReason   String?   @map("fraud_flag_reason")
  createdAt         DateTime  @default(now()) @map("created_at")

  customer          Profile?  @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("returns")
}

// ─────────────────────────────────────────────
// P2P Products
// ─────────────────────────────────────────────
model P2pProduct {
  id               String    @id @default(uuid())
  title            String
  price            Decimal   @db.Decimal(10, 2)
  originalPrice    Decimal?  @db.Decimal(10, 2) @map("original_price")
  category         String
  location         String?
  sellerId         String?   @map("seller_id")
  sellerName       String    @map("seller_name")
  sellerImg        String?   @map("seller_img")
  sellerMemberSince String?  @map("seller_member_since")
  sellerItemsCount Int       @default(0) @map("seller_items_count")
  verified         Boolean   @default(false)
  condition        String
  rating           Decimal   @default(5.0) @db.Decimal(2, 1)
  reviewsCount     Int       @default(0) @map("reviews_count")
  description      String?
  image            String?
  thumbnails       Json      @default("[]")
  timeAgo          String?   @map("time_ago")
  lat              Float?
  lng              Float?
  sellerPhone      String?   @map("seller_phone")
  aiRequestId      String?   @map("ai_request_id")
  aiStatus         String?   @map("ai_status")
  grade            String?
  defects          Json      @default("[]")
  createdAt        DateTime  @default(now()) @map("created_at")

  seller           Profile?  @relation(fields: [sellerId], references: [id], onDelete: SetNull)

  @@map("p2p_products")
}

// ─────────────────────────────────────────────
// P2P Chats
// ─────────────────────────────────────────────
model P2pChat {
  id          String       @id @default(uuid())
  category    String       @default("buying")
  itemTitle   String       @map("item_title")
  itemPrice   Decimal      @db.Decimal(10, 2) @map("item_price")
  itemImage   String?      @map("item_image")
  senderName  String?      @map("sender_name")
  senderImg   String?      @map("sender_img")
  createdAt   DateTime     @default(now()) @map("created_at")

  messages    P2pMessage[]

  @@map("p2p_chats")
}

// ─────────────────────────────────────────────
// P2P Messages
// ─────────────────────────────────────────────
model P2pMessage {
  id         String   @id @default(uuid())
  chatId     String   @map("chat_id")
  senderName String   @map("sender_name")
  text       String
  isMe       Boolean  @default(false) @map("is_me")
  createdAt  DateTime @default(now()) @map("created_at")

  chat       P2pChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@map("p2p_messages")
}

// ─────────────────────────────────────────────
// NGO Campaigns
// ─────────────────────────────────────────────
model NgoCampaign {
  id          String   @id @default(uuid())
  title       String
  ngoName     String   @map("ngo_name")
  ngoLogo     String?  @map("ngo_logo")
  description String?
  image       String?
  urgency     String   @default("standard")
  category    String
  progress    Int      @default(0)
  received    Decimal  @default(0) @db.Decimal(10, 2)
  target      Decimal  @db.Decimal(10, 2)
  unit        String
  location    String?
  state       String?
  founder            String?  @map("founder")
  contactPerson      String?  @map("contact_person")
  contactEmail       String?  @map("contact_email")
  contactPhone       String?  @map("contact_phone")
  registrationNumber String?  @map("registration_number")
  foundedYear        Int?     @map("founded_year")
  address            String?
  missionStatement   String?  @map("mission_statement")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ngo_campaigns")
}

// ─────────────────────────────────────────────
// Donation History
// ─────────────────────────────────────────────
model DonationHistory {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  date      String
  ngo       String
  logo      String?
  action    String
  credits   Int
  isMe      Boolean  @default(true) @map("is_me")
  createdAt DateTime @default(now()) @map("created_at")

  user      Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("donation_history")
}

// ─────────────────────────────────────────────
// Leaderboard
// ─────────────────────────────────────────────
model Leaderboard {
  rank          Int    @id
  name          String
  verifiedCount Int    @default(0) @map("verified_count")
  accuracy      String
  avgSpeed      String @map("avg_speed")
  score         Int    @default(0)

  @@map("leaderboard")
}
