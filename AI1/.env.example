# ── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Request limits ──────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=10485760
MAX_FILES_PER_REQUEST=12
IDEMPOTENCY_TTL_SECONDS=86400
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=60
FRAUD_IP_RATE_LIMIT_MAX=3
FRAUD_IP_RATE_LIMIT_WINDOW_SECONDS=900
DOMESTIC_COUNTRY=IN

# ── AWS ──────────────────────────────────────────────────────────────
# For local dev these are dummy values consumed by docker-compose's
# dynamodb-local + MinIO. Replace with real values for production.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
S3_BUCKET_NAME=ai-grading-returns
DYNAMODB_TABLE_NAME=AIGradingRequests

# Set these to hit local docker-compose services. Leave unset in real AWS.
S3_ENDPOINT=http://localhost:9000
DYNAMODB_ENDPOINT=http://localhost:8000
S3_FORCE_PATH_STYLE=true

# ── AI Models ────────────────────────────────────────────────────────
PYTHON_AI_ENGINE_URL=http://localhost:8000
GEMMA_API_KEY=replace-me
GEMMA_MODEL=gemma-4-26b-a4b-it
MODEL_TIMEOUT_MS=100000

# ── Circuit breaker ──────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=120000

# ── Sweeper ──────────────────────────────────────────────────────────
SWEEPER_INTERVAL_MS=60000
SWEEPER_STUCK_THRESHOLD_MS=300000
